# Server config for the static export on Hostinger (LiteSpeed/Apache).
# Lives in public/ so `next build` (output: export) copies it into ./out and
# the FTP deploy action ships it to public_html/.htaccess.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS + canonical www host in a single 301 hop (avoids redirect
  # chains). This is what fixes "works on www but not fantintstic.net" and the
  # incognito failures: every fresh visitor is normalised to one working URL.
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.fantintstic.net%{REQUEST_URI} [L,R=301]
</IfModule>

<IfModule mod_headers.c>
  # Never cache HTML, so a redeploy is visible immediately and a stale cached
  # page can't mask a broken one (the root of the "fine for me, broken in
  # incognito" symptom).
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Next emits content-hashed asset filenames, so they're safe to cache forever.
  <FilesMatch "\.(css|js|woff2?|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
